# vim: set ft=bash

LFS_HOME="/lfs/local/0/ranjanr"
if [[ -d $LFS_HOME ]]
then
	export HOME="$LFS_HOME"
fi
echo HOME="$HOME"
cd

# if not interactive, exit
[[ $- != *i* ]] && return

FISH_SHELL="$HOME/.pixi/bin/fish"
if [[ -x $FISH_SHELL ]]
then
	export SHELL="$FISH_SHELL"
fi
echo SHELL="$SHELL"
exec $SHELL

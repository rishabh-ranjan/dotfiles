#!/usr/bin/env bash
# gpu-usage — visual summary of GPU usage on the ILC SLURM cluster.
# Shows, per node, how many GPUs are busy/free (with the users holding them),
# plus a per-GPU-type summary of used vs free.
#
# For nodes where YOU hold a GPU allocation, it additionally attaches to your
# job (srun --jobid --overlap) and shows live per-GPU wattage, utilization and
# memory usage. Live stats are only obtainable for GPUs allocated to you —
# the cluster's cgroup device confinement hides other users' GPUs from
# nvidia-smi, so those rows show the SLURM allocation view only.
set -euo pipefail

if ! command -v sinfo >/dev/null 2>&1; then
    echo "error: SLURM (sinfo) not found in PATH" >&2
    exit 1
fi

# Colors (disabled if not a tty)
if [[ -t 1 ]]; then
    R=$'\e[31m'; G=$'\e[32m'; Y=$'\e[33m'; B=$'\e[34m'; C=$'\e[36m'; DIM=$'\e[2m'; BOLD=$'\e[1m'; N=$'\e[0m'
else
    R=; G=; Y=; B=; C=; DIM=; BOLD=; N=
fi

tmp=$(mktemp -d)
trap 'rm -rf "$tmp"' EXIT

# Run srun outside any inherited SLURM allocation (this tool may itself be
# invoked from within a job step).
nosched() {
    local v
    for v in $(compgen -v | grep '^SLURM' || true); do unset "$v"; done
    "$@"
}

# --- node capacity: node|type|total ------------------------------------------
# sinfo emits one line per node/partition; dedupe by node name.
sinfo -N -h -o "%N|%G" | sort -u | while IFS='|' read -r node gres; do
    [[ "$gres" == "(null)" || -z "$gres" ]] && continue
    # gres like: gpu:a100:8  (may carry (S:..) suffixes or comma lists)
    echo "$gres" | tr ',' '\n' | while read -r g; do
        [[ "$g" == gpu:* ]] || continue
        gtype=$(echo "$g" | cut -d: -f2)
        [[ "$gtype" == a100* ]] || continue
        gcnt=$(echo "$g" | cut -d: -f3 | sed 's/(.*//')
        [[ "$gcnt" =~ ^[0-9]+$ ]] || gcnt=0
        echo "$node|$gtype|$gcnt"
    done
done | sort -u > "$tmp/cap"

# --- usage: node|user|jobname|gpus_used --------------------------------------
squeue -h -t R -O "UserName:|,Name:|,NumNodes:|,NodeList:|,tres-alloc:|" | \
while IFS='|' read -r user jobname nnodes nodelist tres _; do
    user=$(echo "$user" | xargs)
    jobname=$(echo "$jobname" | xargs)
    nnodes=$(echo "$nnodes" | xargs)
    nodelist=$(echo "$nodelist" | xargs)
    [[ -z "$nodelist" ]] && continue
    [[ -z "$jobname" ]] && jobname="?"
    # total gpus for this job
    gpu=$(echo "$tres" | grep -oE 'gres/gpu=[0-9]+' | head -1 | cut -d= -f2 || true)
    [[ "$gpu" =~ ^[0-9]+$ ]] || gpu=0
    [[ "$gpu" -eq 0 ]] && continue
    [[ "$nnodes" =~ ^[0-9]+$ ]] || nnodes=1
    per=$(( gpu / nnodes )); (( per < 1 )) && per=1
    for nd in $(scontrol show hostnames "$nodelist"); do
        echo "$nd|$user|$jobname|$per"
    done
done > "$tmp/use"

# --- live per-GPU stats for MY jobs: node|idx|power|util|mem_used|mem_total --
# Attach to each of my running GPU jobs and read nvidia-smi from inside its
# cgroup (the only place those GPUs are visible). Gather nodes in parallel.
: > "$tmp/stats"
# Read into a file first: a `squeue | while` pipe would run the loop in a
# subshell, so the backgrounded sruns would be orphaned from the outer `wait`.
squeue -h -u "$USER" -t R -O "JobID:|,Name:|,NodeList:|,tres-alloc:|" > "$tmp/myjobs"
while IFS='|' read -r jid jobname nodelist tres _; do
    jid=$(echo "$jid" | xargs)
    jobname=$(echo "$jobname" | xargs)
    nodelist=$(echo "$nodelist" | xargs)
    echo "$tres" | grep -qE 'gres/gpu=[1-9]' || continue
    for nd in $(scontrol show hostnames "$nodelist"); do
        (
            nosched timeout 25 srun --jobid="$jid" --overlap -w "$nd" --ntasks=1 \
                nvidia-smi --query-gpu=index,power.draw,utilization.gpu,memory.used,memory.total \
                --format=csv,noheader,nounits </dev/null 2>/dev/null \
            | awk -v nd="$nd" -v jn="$jobname" -F', *' 'NF>=5 && $1 ~ /^[0-9]+$/ {
                  print jn"|"nd"|"$1"|"$2"|"$3"|"$4"|"$5 }' \
            > "$tmp/stats.$jid.$nd" 2>/dev/null || true
        ) &
    done
done < "$tmp/myjobs"
wait
cat "$tmp"/stats.*.* 2>/dev/null > "$tmp/stats" || true

# --- render ------------------------------------------------------------------
awk -F'|' -v R="$R" -v G="$G" -v Y="$Y" -v B="$B" -v C="$C" -v DIM="$DIM" -v BOLD="$BOLD" -v N="$N" -v ME="$USER" '
function bar(used, mine, total,   i, s) {
    # mine (this user) -> green filled; other users -> red filled; free -> dim empty
    s=""
    for (i=0; i<total; i++) {
        if (i<mine)      s = s G"\xe2\x96\xa0"
        else if (i<used) s = s R"\xe2\x96\xa0"
        else             s = s DIM"\xe2\x96\xa1"
    }
    return s N
}
function meter(pct, col, cells,   i, f, s) {
    # horizontal fill meter, `cells` wide, colored
    if (pct<0) pct=0; if (pct>100) pct=100
    f = int(pct/100*cells + 0.5)
    s = col
    for (i=0;i<cells;i++) s = s (i<f ? "\xe2\x96\x88" : DIM"\xe2\x96\x91" col)
    return s N
}
function hcol(pct) { return (pct>=80?R:(pct>=30?Y:G)) }
FILENAME==capf {
    cap[$1]=$3; type[$1]=$2
    next
}
FILENAME==usef {
    used[$1] += $4
    if ($2==ME) mine[$1] += $4
    next
}
FILENAME==statf {
    # jobname|node|idx|power|util|mem_used|mem_total
    jn=$1; nd=$2; idx=$3
    r=++nstat
    sjob[r]=jn; snd[r]=nd; sidx[r]=idx
    spow[r]=$4; sutil[r]=$5; smu[r]=$6; smt[r]=$7
    next
}
END {
    # ---- per-node summary: free / mine / other -----------------------------
    nn=0
    for (nd in cap) nlist[++nn]=nd
    for (ai=1;ai<=nn;ai++) for (bi=ai+1;bi<=nn;bi++) if (nlist[bi]<nlist[ai]){t=nlist[ai];nlist[ai]=nlist[bi];nlist[bi]=t}

    printf "\n%sGPU usage — ILC a100%s\n\n", BOLD, N
    for (ai=1;ai<=nn;ai++) {
        nd=nlist[ai]; u=used[nd]+0; c=cap[nd]+0; m=mine[nd]+0
        if (u>c) u=c; if (m>u) m=u
        oth=u-m; fr=c-u
        printf "  %-9s %s  %sfree %d%s  %smine %d%s  %sother %d%s\n", nd, bar(u,m,c), \
            G, fr, N, (m>0?G:DIM), m, N, (oth>0?R:DIM), oth, N
    }

    # ---- my jobs: per-GPU live stats, grouped by job name ------------------
    njob=0
    for (r=1;r<=nstat;r++) if (!(sjob[r] in jseen)) { jseen[sjob[r]]=1; jlist[++njob]=sjob[r] }
    if (njob>0) printf "\n"
    for (ji=1;ji<=njob;ji++) {
        jn=jlist[ji]
        printf "  %s%s%s\n", BOLD, jn, N
        for (r=1;r<=nstat;r++) {
            if (sjob[r]!=jn) continue
            ut=sutil[r]+0; po=spow[r]+0; mu=smu[r]+0; mt=smt[r]+0
            mpct=(mt>0?mu*100/mt:0)
            printf "    %s%s:%d%s  util %s %s%3d%%%s  mem %s %s%4.1f/%.0fG%s  %s%3.0fW%s\n", \
                DIM, snd[r], sidx[r], N, \
                meter(ut, hcol(ut), 8), hcol(ut), ut, N, \
                meter(mpct, hcol(mpct), 8), hcol(mpct), mu/1024, mt/1024, N, \
                C, po, N
        }
    }
    printf "\n"
}
' capf="$tmp/cap" usef="$tmp/use" statf="$tmp/stats" "$tmp/cap" "$tmp/use" "$tmp/stats"
